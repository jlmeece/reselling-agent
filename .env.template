# ============================================================
# WAT Reselling Agent — Environment Template
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# === AGENT CORE ===
ANTHROPIC_API_KEY=

# === GOOGLE ===
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_FILE=google_credentials.json

# === GOOGLE APIs ===
YOUTUBE_API_KEY=
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=

# === ALERTS ===
# Alert verbosity: "all" (every run), "important" (Tier 1 + errors + sale expiry), "urgent" (errors/OOS only)
ALERT_LEVEL=important
ALERT_FROM_EMAIL=
ALERT_FROM_PASSWORD=
ALERT_TO_EMAIL=
ALERT_TO_SMS=

# === EBAY SELLER HUB ===
# Match exact policy names from: Seller Hub → Account → Business Policies
EBAY_SHIPPING_PROFILE=
EBAY_RETURN_PROFILE=
EBAY_PAYMENT_PROFILE=
EBAY_LOCATION=

# === HERMES GATEWAY (VPS only) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=        # Your personal Telegram chat ID — get it by messaging @userinfobot
HERMES_LLM_PROVIDER=anthropic
HERMES_MODEL=claude-sonnet-4-6

# === COOKIE SYNC (GitHub Gist) ===
# Used by tools/cookie_sync.py to push/pull costco_cookies.json between local and VPS.
# Setup: github.com/settings/tokens → New token → check 'gist' scope only.
GITHUB_TOKEN=
GIST_ID=                 # Populated after first run of: python tools/cookie_sync.py upload

# === HEALTHCHECKS (optional — dead-man monitors) ===
HEALTHCHECK_URL_DISCOVERY=
HEALTHCHECK_URL_RESEARCH=
HEALTHCHECK_URL_DAILY=
HEALTHCHECK_URL_ROTATION=
